# Postgres connection string (Neon). Get this from your Neon project dashboard
# -> Connection Details -> "Pooled connection" string.
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# bcrypt hash of the admin panel login password (replaces the prototype's
# hardcoded "admin2026"). Generate one with:
#   node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
# IMPORTANT: Next.js expands $VAR references in .env files, and bcrypt hashes
# contain "$2b$10$..." sequences that look like variable references. Escape
# every "$" as "\$" or the hash will get silently truncated at runtime.
ADMIN_PASSWORD_HASH="\$2b\$10\$change-me"

# NextAuth secret used to sign admin session tokens.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"

# Base URL of the deployed app, used by NextAuth for callback URLs.
NEXTAUTH_URL="http://localhost:3000"

# Supabase Storage — used for product & category image uploads
# (src/app/api/admin/upload/route.ts). Get these from your Supabase project
# -> Settings -> API. SUPABASE_SERVICE_ROLE_KEY is used server-side only
# (it bypasses Row Level Security) — never expose it to the client or
# prefix it with NEXT_PUBLIC_.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="change-me"
SUPABASE_SERVICE_ROLE_KEY="change-me"
SUPABASE_BUCKET_NAME="product-images"
