# Postgres connection string (Neon). Get this from your Neon project dashboard
# -> Connection Details -> "Pooled connection" string.
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Admin panel login password (replaces the prototype's hardcoded "admin2026").
# Generate a strong value for real use, e.g.: openssl rand -base64 24
ADMIN_PASSWORD="change-me"

# NextAuth secret used to sign admin session tokens.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"

# Base URL of the deployed app, used by NextAuth for callback URLs.
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare R2 (S3-compatible) bucket used for product image uploads.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="perfect-shoes-images"
R2_PUBLIC_URL="https://your-bucket-public-url.example.com"
